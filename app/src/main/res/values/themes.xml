<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--    No Actionbar theme-->
    <style name="Theme.Krushimitra_NoActionBar" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryVariant">@color/green_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/green_secondary</item>
        <item name="colorSecondaryVariant">@color/green_dark</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="android:statusBarColor">@color/green_dark</item>
        <item name="android:navigationBarColor">@color/white</item>

        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">@color/gray_dark</item>
    </style>

    <!-- Light Theme with ActionBar -->
    <style name="Theme.Krushimitra" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryVariant">@color/green_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary colors -->
        <item name="colorSecondary">@color/green_secondary</item>
        <item name="colorSecondaryVariant">@color/green_dark</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Status & navigation bars -->
        <item name="android:statusBarColor">@color/green_dark</item>
        <item name="android:navigationBarColor">@color/white</item>


        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">@color/gray_dark</item>
    </style>

    <!-- ActionBar Custom Style -->
    <style name="Theme.Krushimitra.ActionBar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/green_primary</item>
        <item name="android:titleTextColor">@color/white</item>
        <item name="elevation">4dp</item>
    </style>
</resources>
